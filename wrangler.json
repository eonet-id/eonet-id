{
	"name": "eonet-id",
	"compatibility_date": "2026-03-01",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"analytics_engine_datasets": [
		{ "binding": "ANALISTIC_ENGINE", "dataset": "analystic_event" }
	],
	"upload_source_maps": true
}
